# Example .env for ownEvo development.
#
# Copy to .env (gitignored) and fill in the values you need.
# For a fully-local LMS preset, see `.env.local-lms.example` instead.
#
# Full reference: docs/ENV_VARS.md
# Local-backend recipes: docs/local-model-testing.md

# ---------------------------------------------------------------------------
# Required — runtime
# ---------------------------------------------------------------------------

# Postgres for the kernel. `make dev-up` provisions one locally on :5432.
OWNEVO_DATABASE_URL=postgresql://ownevo:ownevo@localhost:5432/ownevo

# Anthropic API key. Required for NL-gen and any agent run that talks to
# cloud Anthropic. Local-only setups can leave this set to a placeholder
# (`local`) — local backends ignore the value.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional — point Anthropic-format calls at a self-hosted endpoint
# ---------------------------------------------------------------------------
# When set, every `AsyncAnthropic` site (nl_gen, workflows iteration, etc.)
# routes through this base URL. Empty value falls back to the SDK default
# (cloud). See docs/local-model-testing.md for the protocol map.
#
# LMS Anthropic-compat:    http://192.168.1.50:1234
# LiteLLM Anthropic proxy: http://localhost:4000
# ANTHROPIC_BASE_URL=

# ---------------------------------------------------------------------------
# Optional — per-surface model overrides
# ---------------------------------------------------------------------------
# Each LLM-calling kernel surface has its own override. The override chain
# is: caller `model=`  →  env var  →  hardcoded `DEFAULT_MODEL`.
#
# Unset values keep the cloud defaults (opus 4.7 / sonnet 4.6 / haiku 4.5).
# See docs/ENV_VARS.md §5 for the full table.

# NL-gen pipeline — workflow_spec, sim plan, metric definition, eval cases.
# OWNEVO_NL_GEN_MODEL=

# Evolution loop's instruction-edit proposer.
# OWNEVO_INSTRUCTION_PROPOSER_MODEL=

# NL-gen meta-eval judge (W5 ≥0.7 calibration anchor).
# OWNEVO_META_EVAL_MODEL=

# Per-case classifier in the agent solver. Default: claude-haiku-4-5-20251001.
# Override to claude-sonnet-4-6 for multi-tool workflows (3+ tools, multi-step
# reasoning) — Haiku produces scattered failures the proposer can't cluster on
# complex flows. See docs/local-model-testing.md "Cloud model picks per surface"
# for the empirical 50%→100% lift evidence.
# OWNEVO_AGENT_SOLVER_MODEL=claude-sonnet-4-6

# Cluster labeller (short factual cluster names).
# OWNEVO_CLUSTER_LABEL_MODEL=

# Cluster label-judge (must differ from labeller — D4 separation rule).
# OWNEVO_CLUSTER_JUDGE_MODEL=

# LLM-as-judge approver (W5.2 ≥0.85 calibration anchor).
# OWNEVO_APPROVER_MODEL=

# Improvement loop driver (the manual agentic loop over /v1/messages).
# OWNEVO_LOOP_MODEL=

# ---------------------------------------------------------------------------
# Optional — local LLM backends for dev scripts (run_improvement_loop.py etc.)
# ---------------------------------------------------------------------------
# Separate from the kernel HTTP API. Set when running M5 / τ³ scripts
# directly. See docs/ENV_VARS.md §3 + docs/local-model-testing.md.

# Host of the local LLM box. Used by shell scripts to build base URLs.
# OWNEVO_LLM_HOST=192.168.1.50

# Direct overrides used by `run_improvement_loop.py`:
# OWNEVO_LLM_BASE_URL=http://192.168.1.50:1234
# OWNEVO_LLM_MODEL=qwen/qwen3.6-35b-a3b
# OWNEVO_LLM_API_FORMAT=anthropic   # anthropic | openai
# OWNEVO_LLM_API_KEY=local

# ---------------------------------------------------------------------------
# Optional — live-API tests
# ---------------------------------------------------------------------------
# Set to 1 to opt NL-gen snapshot tests into hitting the real API.
# OWNEVO_ANTHROPIC_LIVE=

# Model used by those tests. Defaults to haiku.
# OWNEVO_NL_GEN_LIVE_MODEL=
