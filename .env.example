# Example .env for ownEvo development.
#
# Copy to .env (gitignored) and fill in the values you need.
# For a fully-local LMS preset, see `.env.local-lms.example` instead.
#
# Full reference: docs/ENV_VARS.md
# Local-backend recipes: docs/local-model-testing.md

# ---------------------------------------------------------------------------
# Required — runtime
# ---------------------------------------------------------------------------

# Postgres for the kernel. `make dev-up` provisions one locally on :5432.
OWNEVO_DATABASE_URL=postgresql://ownevo:ownevo@localhost:5432/ownevo

# Connection pool sizing and per-connection statement_timeout.
# Defaults are tuned for a single Next.js dev server in front of the kernel;
# raise the max for a higher-concurrency deployment. The statement_timeout is
# applied via the pool's setup hook on every acquire (asyncpg's pool issues
# DISCARD ALL on release, which would otherwise clear the SET). Setting the
# timeout to 0 disables it; useful for long-running maintenance scripts that
# share the pool, NOT recommended for the API process.
# OWNEVO_DB_POOL_MIN_SIZE=1
# OWNEVO_DB_POOL_MAX_SIZE=10
# OWNEVO_DB_STATEMENT_TIMEOUT_MS=30000

# Authentication (see docs/AUTH.md).
# Production environment marker. Set to "production" in real deploys to activate
# the kernel's production boot guards (refuses dev-auth, asserts required secrets).
# Leave unset in dev and CI. See docs/AUTH.md § "Boot-time guards".
# OWNEVO_ENV=production
# Dev-auth: when "true", API requests with no signed identity assertion
# resolve to the seeded local dev user in the default workspace. `make api`
# sets this automatically for zero-config local runs. Leave UNSET (or "false")
# in production so the kernel fails closed (401) on unauthenticated requests.
# OWNEVO_DEV_AUTH=true
# Shared secret the web app uses to sign the web->kernel identity assertion and
# the kernel uses to verify it. Also authenticates the web app to the kernel's
# internal auth-sync endpoint (presented as a bearer token). Set this (to a
# long random value) in any deployment that authenticates real users; not
# needed under pure dev-auth.
# OWNEVO_INTERNAL_AUTH_KEY=
# Auth.js (web edge) — see docs/AUTH.md. AUTH_SECRET encrypts the JWT session
# cookie; required whenever the web app serves sign-in (any non-dev deploy).
# Generate with `openssl rand -base64 32`.
# AUTH_SECRET=
# Google OIDC provider credentials. The web app registers the Google sign-in
# button only when both are present; absent (local/dev) it falls back to the
# dev credentials provider gated on OWNEVO_DEV_AUTH=true.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Anthropic API key. Required for NL-gen and any agent run that talks to
# cloud Anthropic. Local-only setups can leave this set to a placeholder
# (`local`) — local backends ignore the value.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional — point Anthropic-format calls at a self-hosted endpoint
# ---------------------------------------------------------------------------
# When set, every `AsyncAnthropic` site (nl_gen, workflows iteration, etc.)
# routes through this base URL. Empty value falls back to the SDK default
# (cloud). See docs/local-model-testing.md for the protocol map.
#
# LMS Anthropic-compat:    http://<your-inference-host>:1234
# LiteLLM Anthropic proxy: http://localhost:4000
# ANTHROPIC_BASE_URL=

# ---------------------------------------------------------------------------
# Optional — per-surface model overrides
# ---------------------------------------------------------------------------
# Each LLM-calling kernel surface has its own override. The override chain
# is: caller `model=`  →  env var  →  hardcoded `DEFAULT_MODEL`.
#
# Unset values keep the cloud defaults (opus 4.7 / sonnet 4.6 / haiku 4.5).
# See docs/ENV_VARS.md §5 for the full table.

# NL-gen pipeline — workflow_spec, sim plan, metric definition, eval cases.
# OWNEVO_NL_GEN_MODEL=

# Evolution loop's instruction-edit proposer.
# OWNEVO_INSTRUCTION_PROPOSER_MODEL=

# NL-gen meta-eval judge (W5 ≥0.7 calibration anchor).
# OWNEVO_META_EVAL_MODEL=

# Per-case classifier in the agent solver. Default: claude-haiku-4-5-20251001.
# Override to claude-sonnet-4-6 for multi-tool workflows (3+ tools, multi-step
# reasoning) — Haiku produces scattered failures the proposer can't cluster on
# complex flows. See docs/local-model-testing.md "Cloud model picks per surface"
# for the empirical 50%→100% lift evidence.
# OWNEVO_AGENT_SOLVER_MODEL=claude-sonnet-4-6

# Cluster labeller (short factual cluster names).
# OWNEVO_CLUSTER_LABEL_MODEL=

# Cluster label-judge (must differ from labeller — D4 separation rule).
# OWNEVO_CLUSTER_JUDGE_MODEL=

# LLM-as-judge approver (W5.2 ≥0.85 calibration anchor).
# OWNEVO_APPROVER_MODEL=

# Improvement loop driver (the manual agentic loop over /v1/messages).
# OWNEVO_LOOP_MODEL=

# ---------------------------------------------------------------------------
# Per-workflow agent-model picker — provider allowlist
# ---------------------------------------------------------------------------
# The web Settings page exposes a per-workflow model picker; the dropdown's
# options come from the runtime-enabled providers below. Each provider is a
# pair of flags: `_ENABLED` gates the provider; `_MODELS` is a comma-
# separated list of model ids the operator wants exposed. Disable a provider
# by setting `_ENABLED=false` or by leaving `_MODELS` blank.
#
# Slugs stored on `workflows.agent_model_id` are `provider:model`
# (e.g. `anthropic:claude-sonnet-4-6`, `openrouter:moonshotai/kimi-k2`).
# The `PATCH /api/workflows/{id}/agent-model` endpoint validates against
# the union of every enabled provider's allowed models.

# Anthropic (default — required for kernel surfaces still using the SDK direct).
OWNEVO_PROVIDER_ANTHROPIC_ENABLED=true
OWNEVO_PROVIDER_ANTHROPIC_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5

# OpenAI direct. Needs OPENAI_API_KEY.
OWNEVO_PROVIDER_OPENAI_ENABLED=false
OWNEVO_PROVIDER_OPENAI_MODELS=gpt-5.5
# OPENAI_API_KEY=

# xAI direct. Needs XAI_API_KEY.
OWNEVO_PROVIDER_XAI_ENABLED=false
OWNEVO_PROVIDER_XAI_MODELS=grok-4
# XAI_API_KEY=

# Google Gemini (OpenAI-compat endpoint). Needs GEMINI_API_KEY.
OWNEVO_PROVIDER_GEMINI_ENABLED=false
OWNEVO_PROVIDER_GEMINI_MODELS=gemini-3.1-pro,gemini-3.5-flash
# GEMINI_API_KEY=

# OpenRouter (OpenAI-compat meta-router) — the recommended cloud path when
# you want a cross-vendor selection (Kimi, DeepSeek, Qwen, gpt-oss, Llama,
# Mistral, ...) behind a single key. Needs OPENROUTER_API_KEY.
# Slugs use OpenRouter's `vendor/model` format.
OWNEVO_PROVIDER_OPENROUTER_ENABLED=true
OWNEVO_PROVIDER_OPENROUTER_MODELS=moonshotai/kimi-k2.6,deepseek/deepseek-v4-flash,openai/gpt-oss-120b,z-ai/glm-5.1,nvidia/nemotron-3-super-120b-a12b
# OPENROUTER_API_KEY=

# Local / Custom OpenAI — any self-hosted or on-premise inference server
# exposing an OpenAI-compat /v1/chat/completions endpoint (LM Studio,
# vLLM, llama.cpp server, on-premise gateway, etc.). No API key is
# required for keyless servers; set OWNEVO_LOCAL_API_KEY when your server
# enforces one. OWNEVO_LOCAL_BASE_URL takes precedence; falls back to
# OWNEVO_LLM_BASE_URL, then http://$OWNEVO_LLM_HOST:1234/v1.
OWNEVO_PROVIDER_LOCAL_ENABLED=false
OWNEVO_PROVIDER_LOCAL_MODELS=qwen/qwen3.6-35b-a3b,qwen/qwen3-coder-30b
# OWNEVO_LOCAL_BASE_URL=http://<your-inference-host>:1234/v1
# OWNEVO_LOCAL_API_KEY=local

# Ollama (local, no key) — alternative local path that routes through
# OllamaChatClient (`/api/chat`) so `options.think=false` reaches
# qwen3-family models. Host comes from $OWNEVO_LLM_HOST (default
# localhost) on port 11434.
OWNEVO_PROVIDER_OLLAMA_ENABLED=false
OWNEVO_PROVIDER_OLLAMA_MODELS=qwen3.6-35b-a3b,qwen/qwen3.6-35b-a3b,qwen3-coder:30b

# ---------------------------------------------------------------------------
# Optional — local LLM backends for dev scripts (run_improvement_loop.py etc.)
# ---------------------------------------------------------------------------
# Separate from the kernel HTTP API. Set when running M5 scripts directly.

# Host of the local inference box. Used by shell scripts to build base URLs.
# OWNEVO_LLM_HOST=<your-inference-host>

# Direct overrides used by `run_improvement_loop.py`:
# OWNEVO_LLM_BASE_URL=http://<your-inference-host>:1234
# OWNEVO_LLM_MODEL=qwen/qwen3.6-35b-a3b
# OWNEVO_LLM_API_FORMAT=anthropic   # anthropic | openai
# OWNEVO_LLM_API_KEY=local

# ---------------------------------------------------------------------------
# Optional — live-API tests
# ---------------------------------------------------------------------------
# Set to 1 to opt NL-gen snapshot tests into hitting the real API.
# OWNEVO_ANTHROPIC_LIVE=

# Model used by those tests. Defaults to haiku.
# OWNEVO_NL_GEN_LIVE_MODEL=

# ---------------------------------------------------------------------------
# Optional — sandbox admission control
# ---------------------------------------------------------------------------
# Maximum concurrent `docker run` invocations across all LocalDockerSandbox
# instances in the process. Sized for one API host: each container holds 1
# CPU + memory_mb of RAM by default, so 4 in flight fits comfortably on a
# 4-vCPU / 8GB machine. Raise on larger hosts; lower for dev laptops.
# OWNEVO_SANDBOX_MAX_CONCURRENT=4

# ---------------------------------------------------------------------------
# Optional — structured (JSON) logging
# ---------------------------------------------------------------------------
# When set to "json", every log record is emitted as one JSON object per
# line so log shippers (Datadog, Loki, Cloud Logging) can ingest the
# stream directly. The exception handler's structured fields
# (request_id, error_id, method, path, exc_class) become top-level
# attributes in the JSON payload. Leave unset for human-readable logs.
# OWNEVO_LOG_FORMAT=json
