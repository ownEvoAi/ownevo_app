# Example .env for an all-local kernel pointed at LM Studio.
#
# Copy to .env (gitignored), edit the host, then `make dev-up` /
# `docker compose up -d --force-recreate kernel`. Every Anthropic-format
# kernel surface (NL-gen, clustering judge, approver, etc.) routes to
# the LMS endpoint below; the per-surface model env vars send each
# surface to its own loaded model (use the same model for all surfaces
# if you're only loading one).
#
# Prerequisites in LM Studio:
#   - Load `qwen/qwen3.6-35b-a3b` (or another local model) with the
#     froggeric chat_template-v13.jinja override and ctx=65536. JIT off.
#   - The LMS Anthropic-compat endpoint is on `:1234` by default.
#
# See docs/local-model-testing.md for the validation recipe and
# per-surface protocol map. CLAUDE.local.md (gitignored) has the
# τ³-tested model picks and current dogfooding notes.

# ---------------------------------------------------------------------------
# Required — runtime
# ---------------------------------------------------------------------------
OWNEVO_DATABASE_URL=postgresql://ownevo:ownevo@localhost:5432/ownevo

# Local backends ignore this value, but the env var must be non-empty
# so the SDK initializes without a 503 / KeyError.
ANTHROPIC_API_KEY=local

# ---------------------------------------------------------------------------
# Route every Anthropic-format kernel call to LMS
# ---------------------------------------------------------------------------
# Change the host to match your LMS box. `192.168.1.50` is the dev box;
# `localhost` if LMS runs on the same machine as the kernel.
ANTHROPIC_BASE_URL=http://192.168.1.50:1234

# ---------------------------------------------------------------------------
# Per-surface model overrides
# ---------------------------------------------------------------------------
# Keep all surfaces on the same model when you have a single LMS instance
# loaded. Switch per-surface if you load multiple models concurrently.
#
# The model id must match what `GET /v1/models` returns on the LMS box —
# `instance_id` (with context-length suffix) for explicitly-loaded models.

OWNEVO_NL_GEN_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_INSTRUCTION_PROPOSER_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_META_EVAL_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_AGENT_SOLVER_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_CLUSTER_LABEL_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_CLUSTER_JUDGE_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_APPROVER_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_LOOP_MODEL=qwen/qwen3.6-35b-a3b

# ---------------------------------------------------------------------------
# Dev-script env (run_improvement_loop.py, τ³ runners)
# ---------------------------------------------------------------------------
# The HTTP API reads the OWNEVO_*_MODEL vars above. These additional vars
# only apply when you run the scripts in `apps/kernel/scripts/` directly.
OWNEVO_LLM_HOST=192.168.1.50
OWNEVO_LLM_BASE_URL=http://192.168.1.50:1234
OWNEVO_LLM_MODEL=qwen/qwen3.6-35b-a3b
OWNEVO_LLM_API_FORMAT=anthropic
OWNEVO_LLM_API_KEY=local
