{
  "$defs": {
    "AgentTool": {
      "additionalProperties": false,
      "description": "A tool the agent calls. Becomes a tool_use definition at runtime\nand a Python function stub in the generated sim module.",
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "inputs": {
          "items": {
            "$ref": "#/$defs/ToolParam"
          },
          "title": "Inputs",
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "outputs": {
          "items": {
            "$ref": "#/$defs/ToolParam"
          },
          "title": "Outputs",
          "type": "array"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ],
      "title": "AgentTool",
      "type": "object"
    },
    "AlertList": {
      "additionalProperties": false,
      "description": "Markdown alerts, escalations, clause flags.",
      "properties": {
        "severity_field": {
          "default": "severity",
          "title": "Severity Field",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "title_field": {
          "default": "title",
          "title": "Title Field",
          "type": "string"
        },
        "type": {
          "const": "AlertList",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "source"
      ],
      "title": "AlertList",
      "type": "object"
    },
    "ConversationView": {
      "additionalProperties": false,
      "description": "Multi-turn agent transcript with citations.",
      "properties": {
        "trace_source": {
          "title": "Trace Source",
          "type": "string"
        },
        "type": {
          "const": "ConversationView",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "trace_source"
      ],
      "title": "ConversationView",
      "type": "object"
    },
    "DataSource": {
      "additionalProperties": false,
      "description": "An external system the agent pulls from (SAP ERP, NOAA, Salesforce).\n\nIn production these are live integrations; in the simulator (A3.2) they're\ndeterministic replayers.",
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "entity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entity"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id"
      ],
      "title": "DataSource",
      "type": "object"
    },
    "DocumentReader": {
      "additionalProperties": false,
      "description": "Contracts, policies, runbooks with margin annotations.",
      "properties": {
        "annotations_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Annotations Source"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "type": {
          "const": "DocumentReader",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "source"
      ],
      "title": "DocumentReader",
      "type": "object"
    },
    "Entity": {
      "additionalProperties": false,
      "description": "A first-class thing the agent reads or manipulates (sku, ticket, contract).",
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/EntityField"
          },
          "title": "Fields",
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Entity",
      "type": "object"
    },
    "EntityField": {
      "additionalProperties": false,
      "description": "One named, typed field on an Entity.",
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "type": {
          "enum": [
            "string",
            "int",
            "float",
            "bool",
            "date",
            "datetime",
            "category"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "EntityField",
      "type": "object"
    },
    "EnvGenerator": {
      "additionalProperties": false,
      "description": "A data-generating component of the simulator.\n\nDistinct from DataSource: data sources are external systems with fixed\nschemas; env generators synthesize realistic data (synthetic catalogs,\nsupplier behaviour, weather anomalies). The sim generator (A3.2) emits\none Python module per env_generator.",
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ],
      "title": "EnvGenerator",
      "type": "object"
    },
    "KanbanBoard": {
      "additionalProperties": false,
      "description": "Tickets by status, deals by stage.",
      "properties": {
        "card_title_field": {
          "title": "Card Title Field",
          "type": "string"
        },
        "column_field": {
          "title": "Column Field",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "type": {
          "const": "KanbanBoard",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "source",
        "column_field",
        "card_title_field"
      ],
      "title": "KanbanBoard",
      "type": "object"
    },
    "MetricCards": {
      "additionalProperties": false,
      "description": "KPI tiles. Used for forecast accuracy, CSAT, $ at risk, etc.",
      "properties": {
        "fields": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Fields",
          "type": "array"
        },
        "type": {
          "const": "MetricCards",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "fields"
      ],
      "title": "MetricCards",
      "type": "object"
    },
    "Persona": {
      "additionalProperties": false,
      "description": "A simulated human interacting with the agent.\n\nMock parity: 04-new-workflow-step2.html \u00a7 \"User behaviour (simulated)\" \u2014\ne.g., \"Supply chain analyst \u00b7 Monday morning markdown review\",\n\"Supply Chain VP \u00b7 daily alert triage\". `name` is optional because the\nuser's description usually says \"the supply chain VP\" not \"Maria\"; the\ndemo workspace populates names elsewhere (see ownEvo_MVP_mocks.md).\n\n`cadence` is free-form prose (\"daily\", \"Monday 9:00 PT\", \"per-incident\");\nA3.2 reads it to schedule sim interactions.",
      "properties": {
        "cadence": {
          "default": "",
          "title": "Cadence",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "role": {
          "minLength": 1,
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role"
      ],
      "title": "Persona",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "How an artifact links back to the user's description.\n\nMock parity: `04-new-workflow-step2.html` shows\n\"derived from <em>\"<phrase>\"</em>\" (kind=\"derived\") or\n\"inferred from <em>supply chain forecasting domain pattern</em>\"\n(kind=\"inferred\"). The demo's load-bearing feature \u2014 every artifact\ntraces back to either a quoted phrase from the user or a named domain\npattern.",
      "properties": {
        "kind": {
          "enum": [
            "derived",
            "inferred"
          ],
          "title": "Kind",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "source"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ReviewerSpec": {
      "additionalProperties": false,
      "description": "Who reviews the agent's outputs and on what cadence.\n\nDrives the approval-queue UI framing and the audit-trail attribution\n(\"approved by <reviewer.role>\"). Distinct from Persona because the\nreviewer is a real human approver, not a simulated user.\n\n`provenance` is optional and consistent with other artifact types \u2014\nthe reviewer is usually named directly in the user's description\n(\"the supply chain VP reviews ...\"), and tracking that lineage shows\nup in the same demo surface.",
      "properties": {
        "cadence": {
          "default": "",
          "title": "Cadence",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "role": {
          "minLength": 1,
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role"
      ],
      "title": "ReviewerSpec",
      "type": "object"
    },
    "SideBySideView": {
      "additionalProperties": false,
      "description": "Contract clause + redline, document diff.",
      "properties": {
        "diff_mode": {
          "default": "text",
          "enum": [
            "text",
            "json"
          ],
          "title": "Diff Mode",
          "type": "string"
        },
        "left_source": {
          "title": "Left Source",
          "type": "string"
        },
        "right_source": {
          "title": "Right Source",
          "type": "string"
        },
        "type": {
          "const": "SideBySideView",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "left_source",
        "right_source"
      ],
      "title": "SideBySideView",
      "type": "object"
    },
    "SuccessCriterionStub": {
      "additionalProperties": false,
      "description": "A3.1 emits this stub. A4.2 reads it and generates the full metric\ndefinition (formula, weights, per-case computation).\n\n`target_metric_name` is a placeholder \u2014 A4.2 may rename when it\ncomposes the actual metric. `direction` is locked here because changing\nit later would invert the gate's improvement check.",
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "direction": {
          "enum": [
            "maximize",
            "minimize"
          ],
          "title": "Direction",
          "type": "string"
        },
        "target_metric_name": {
          "minLength": 1,
          "title": "Target Metric Name",
          "type": "string"
        }
      },
      "required": [
        "direction",
        "target_metric_name",
        "description"
      ],
      "title": "SuccessCriterionStub",
      "type": "object"
    },
    "TableView": {
      "additionalProperties": false,
      "description": "Tabular list. SKU list, ticket queue, line items.",
      "properties": {
        "columns": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Columns",
          "type": "array"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "type": {
          "const": "TableView",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "source",
        "columns"
      ],
      "title": "TableView",
      "type": "object"
    },
    "TimeSeriesChart": {
      "additionalProperties": false,
      "description": "Time-series. Demand forecast, ticket volume, lift charts.",
      "properties": {
        "group_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Group By"
        },
        "type": {
          "const": "TimeSeriesChart",
          "title": "Type",
          "type": "string"
        },
        "x": {
          "title": "X",
          "type": "string"
        },
        "y": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Y",
          "type": "array"
        }
      },
      "required": [
        "type",
        "x",
        "y"
      ],
      "title": "TimeSeriesChart",
      "type": "object"
    },
    "ToolParam": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "type": {
          "enum": [
            "string",
            "int",
            "float",
            "bool",
            "date",
            "datetime",
            "category"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "ToolParam",
      "type": "object"
    },
    "UILayout": {
      "additionalProperties": false,
      "description": "Operate-view layout. Mock parity: `06-workflow-operate.html`.",
      "properties": {
        "layout": {
          "default": "tabs",
          "enum": [
            "tabs",
            "single"
          ],
          "title": "Layout",
          "type": "string"
        },
        "tabs": {
          "items": {
            "$ref": "#/$defs/UITab"
          },
          "minItems": 1,
          "title": "Tabs",
          "type": "array"
        }
      },
      "required": [
        "tabs"
      ],
      "title": "UILayout",
      "type": "object"
    },
    "UITab": {
      "additionalProperties": false,
      "description": "One tab in the workflow's operate-view.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "primitives": {
          "items": {
            "discriminator": {
              "mapping": {
                "AlertList": "#/$defs/AlertList",
                "ConversationView": "#/$defs/ConversationView",
                "DocumentReader": "#/$defs/DocumentReader",
                "KanbanBoard": "#/$defs/KanbanBoard",
                "MetricCards": "#/$defs/MetricCards",
                "SideBySideView": "#/$defs/SideBySideView",
                "TableView": "#/$defs/TableView",
                "TimeSeriesChart": "#/$defs/TimeSeriesChart"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/MetricCards"
              },
              {
                "$ref": "#/$defs/TimeSeriesChart"
              },
              {
                "$ref": "#/$defs/TableView"
              },
              {
                "$ref": "#/$defs/AlertList"
              },
              {
                "$ref": "#/$defs/KanbanBoard"
              },
              {
                "$ref": "#/$defs/ConversationView"
              },
              {
                "$ref": "#/$defs/SideBySideView"
              },
              {
                "$ref": "#/$defs/DocumentReader"
              }
            ]
          },
          "minItems": 1,
          "title": "Primitives",
          "type": "array"
        }
      },
      "required": [
        "name",
        "primitives"
      ],
      "title": "UITab",
      "type": "object"
    },
    "WorkflowEnvironment": {
      "additionalProperties": false,
      "description": "What the agent operates on.\n\nThe sim generator (A3.2) emits one Python module per element: an\nentity-store stub, a data-source replayer per data_source, a generator\nmodule per env_generator, a behaviour script per persona.",
      "properties": {
        "data_sources": {
          "items": {
            "$ref": "#/$defs/DataSource"
          },
          "title": "Data Sources",
          "type": "array"
        },
        "entities": {
          "items": {
            "$ref": "#/$defs/Entity"
          },
          "title": "Entities",
          "type": "array"
        },
        "env_generators": {
          "items": {
            "$ref": "#/$defs/EnvGenerator"
          },
          "title": "Env Generators",
          "type": "array"
        },
        "personas": {
          "items": {
            "$ref": "#/$defs/Persona"
          },
          "title": "Personas",
          "type": "array"
        },
        "seasonality": {
          "items": {
            "type": "string"
          },
          "title": "Seasonality",
          "type": "array"
        }
      },
      "title": "WorkflowEnvironment",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The frozen-schema artifact stored in `workflows.spec` JSONB.\n\nRound-trip identity is the contract: a spec written by the generator\nmust JSON-serialize, store as JSONB, and round-trip back to an\nidentical Python object.\n\nThe user's original description is NOT carried here \u2014 it lives on the\n`workflows.description` column (the source) while `spec` is the\ngenerated structural artifact. Asking the LLM to also echo the\ndescription verbatim is the kind of redundancy small models silently\nparaphrase, so we don't ask. Downstream consumers that need the\ndescription read it off the workflow row.",
  "properties": {
    "domain": {
      "enum": [
        "supply-chain",
        "credit-risk",
        "legal",
        "support",
        "labour",
        "other"
      ],
      "title": "Domain",
      "type": "string"
    },
    "environment": {
      "$ref": "#/$defs/WorkflowEnvironment"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "title": "Id",
      "type": "string"
    },
    "known_past_misses": {
      "items": {
        "type": "string"
      },
      "title": "Known Past Misses",
      "type": "array"
    },
    "reviewer": {
      "$ref": "#/$defs/ReviewerSpec"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "success_criterion": {
      "$ref": "#/$defs/SuccessCriterionStub"
    },
    "tools": {
      "items": {
        "$ref": "#/$defs/AgentTool"
      },
      "minItems": 1,
      "title": "Tools",
      "type": "array"
    },
    "ui": {
      "$ref": "#/$defs/UILayout"
    }
  },
  "required": [
    "id",
    "domain",
    "environment",
    "tools",
    "reviewer",
    "success_criterion",
    "ui"
  ],
  "title": "WorkflowSpec",
  "type": "object"
}
